---
layout: null
permalink: /en/search.json
---
[
{% assign first = true %}
{% for p in site.pages %}
  {% assign page_is_en = false %}
  {% if p.url == '/en/' or p.url contains '/en/' %}
    {% assign page_is_en = true %}
  {% endif %}
  {% if p.title and p.url and p.search != false and page_is_en %}
    {% unless first %},{% endunless %}
    {
      "title": {{ p.title | jsonify }},
      "url": {{ p.url | relative_url | jsonify }},
      "desc": {{ p.desc | default: '' | strip_html | strip_newlines | jsonify }},
      "breadcrumb": {{ p.breadcrumb | default: '' | strip_html | strip_newlines | jsonify }},
      "content": {{ p.content | markdownify | strip_html | strip_newlines | jsonify }}
    }
    {% assign first = false %}
  {% endif %}
{% endfor %}
]
